<UserControl x:Class="ExpressPackingMonitoring.UI.Pages.PcRecordingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="clr-namespace:ExpressPackingMonitoring.Localization"
             Background="{StaticResource TransparentBrush}">
    <UserControl.Resources>
        <localization:LocalizedTextConverter x:Key="LocalizedTextConverter"/>
        <!-- 修复 ComboBox 稳定性问题的核心代码 -->
        <Style TargetType="ComboBoxItem">
            <!-- 手动指定对齐方式，不再让系统去 FindAncestor，从而消除报错 -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Gd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true"
                                CornerRadius="4"
                                Margin="2,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 增加悬浮效果，提升交互感 -->
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource ControlBackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 确保 ComboBox 容器本身也是稳定的 -->
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/> <!-- 禁用像素级滚动有助于稳定性 -->
        </Style>

        <Style TargetType="Button" x:Key="ModernBtn">
            <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid x:Name="RecordingLayout" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="20,16" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding ToggleModeCommand}" Focusable="False" Margin="0,0,16,0" Cursor="Hand" ToolTip="点击切换模式" Height="52" MinWidth="130">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,0">
                                                            <Path x:Name="ModeIcon" Data="{StaticResource FluentBoxIcon}" Width="22" Height="22" Stretch="Uniform" Fill="{StaticResource TextOnAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding CurrentMode, Converter={StaticResource LocalizedTextConverter}}" FontSize="24" FontWeight="Black" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                                            <Setter TargetName="ModeIcon" Property="Data" Value="{StaticResource FluentReturnIcon}"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="退货">
                                                <Setter Property="Background" Value="{DynamicResource AccentOrange}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Grid Grid.Column="1">
                                <TextBox x:Name="ScanInputTextBox" Height="52" FontSize="22" Padding="16,0,36,0" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="2" VerticalContentAlignment="Center"
                                         Text="{Binding ScanInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         GotKeyboardFocus="ScanInputTextBox_GotFocus" PreviewMouseLeftButtonDown="ScanInputTextBox_PreviewMouseLeftButtonDown"
                                         PreviewKeyDown="ScanInputTextBox_PreviewKeyDown" TextChanged="ScanInputTextBox_TextChanged" LostFocus="ScanInputTextBox_LostFocus">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Command="{Binding ClearScanInputCommand}" Focusable="False" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Cursor="Hand" Foreground="{DynamicResource TextMuted}" Background="{StaticResource TransparentBrush}" BorderThickness="0">
                                    <Path Data="{StaticResource FluentDismissIcon}" Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextMuted}"/>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>

                        <Button Grid.Column="1" Command="{Binding ToggleRecordingCommand}" Focusable="False" Height="52" Width="160" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernBtn}">
                                    <Setter Property="Background" Value="{DynamicResource AccentGreen}"/>
                                    <Setter Property="FontWeight" Value="Black"/>
                                    <Setter Property="FontSize" Value="20"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path x:Name="RecordActionIcon" Data="{StaticResource FluentRecordIcon}" Width="20" Height="20" Stretch="Uniform" Fill="{StaticResource TextOnAccent}" Margin="0,0,8,0"/>
                                                        <TextBlock x:Name="RecordActionText" Text="{x:Static localization:AppLanguage.StartRecordingText}" Foreground="{StaticResource TextOnAccent}" FontWeight="{TemplateBinding FontWeight}" FontSize="{TemplateBinding FontSize}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                        <Setter TargetName="RecordActionIcon" Property="Data" Value="{StaticResource FluentStopIcon}"/>
                                                        <Setter TargetName="RecordActionText" Property="Text" Value="{x:Static localization:AppLanguage.StopRecordingText}"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsBusy}" Value="True"/>
                                                            <Condition Binding="{Binding IsShutdownInProgress}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="RecordActionIcon" Property="Data" Value="{StaticResource FluentArrowSyncIcon}"/>
                                                        <Setter TargetName="RecordActionText" Property="Text" Value="{Binding BusyText}"/>
                                                    </MultiDataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentRed}"/>
                                        </DataTrigger>
                                        <!-- 新增：Busy过渡状态，优先于 IsRecording -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsBusy}" Value="True"/>
                                                <Condition Binding="{Binding IsShutdownInProgress}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource DisabledActionBackground}"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsShutdownInProgress}" Value="True">
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                            <Setter Property="Opacity" Value="0.65"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="CameraPreviewBorder" Grid.Row="1" Background="{DynamicResource VideoPlaceholder}" CornerRadius="10" ClipToBounds="True" MouseEnter="CameraPreviewBorder_MouseEnter" MouseLeave="CameraPreviewBorder_MouseLeave">
                    <Grid>
                        <Image x:Name="VideoImage" Source="{Binding VideoFrame}" Stretch="Uniform"/>
                        <Rectangle x:Name="ZoomPreviewBorder"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Stroke="{StaticResource CameraGuideStroke}"
                                   StrokeThickness="3"
                                   StrokeDashArray="4 2"
                                   Fill="{StaticResource TransparentBrush}"
                                   Visibility="Collapsed"
                                   Opacity="1"
                                   RadiusX="2" RadiusY="2"/>
                        <Grid x:Name="CameraBarcodeGuide"
                              Width="0"
                              Height="0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCameraBarcodeRecognitionEnabled}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCameraSleeping}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Rectangle RadiusX="6" RadiusY="6" StrokeThickness="3" StrokeDashArray="6 3">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Stroke" Value="{StaticResource CameraGuideStroke}"/>
                                        <Setter Property="Fill" Value="{StaticResource CameraGuideFill}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeCandidate}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource CameraCandidateStroke}"/>
                                                <Setter Property="Fill" Value="{StaticResource CameraCandidateFill}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeConfirmed}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource CameraConfirmedStroke}"/>
                                                <Setter Property="Fill" Value="{StaticResource CameraConfirmedFill}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,10,0,0"
                                    Padding="12,6"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeCandidate}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentOrange}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCameraBarcodeConfirmed}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding CameraBarcodeStatusText}"
                                           Foreground="{StaticResource TextOnAccent}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Margin="16"
                                    MaxWidth="560"
                                    IsHitTestVisible="False"
                                    localization:AppLanguage.AutoLocalize="False"
                                    Panel.ZIndex="30">
                            <Border CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,8"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Background" Value="{StaticResource WarningOverlay}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource WarningOverlayBorder}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreviewAlertVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPreviewAlertCritical}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource DangerOverlay}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource DangerOverlayBorder}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding PreviewAlertText}"
                                               Foreground="{StaticResource TextOnAccent}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               LineHeight="31"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource OverlayStrong}"
                                    BorderBrush="{StaticResource WarningOverlayBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreviewOrderNoticeVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding PreviewOrderRemarkText}"
                                               Foreground="{StaticResource TextOnAccent}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               LineHeight="31"
                                               Margin="0,0,0,4"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PreviewOrderRemarkText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding PreviewOrderDetailText}"
                                               Foreground="{StaticResource TextOnAccent}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               LineHeight="22"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PreviewOrderDetailText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <!-- 摄像头休眠提示 -->
                        <Grid IsHitTestVisible="False">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCameraSleeping}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Background="{StaticResource OverlayStrong}" CornerRadius="10"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource FluentSleepIcon}" Width="52" Height="52" Stretch="Uniform" Fill="{StaticResource OverlayTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="摄像头已休眠" FontSize="22" FontWeight="Bold" Foreground="{StaticResource OverlayTextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="点击任意位置唤醒，再将面单放入识别框" FontSize="14" Foreground="{StaticResource OverlayTextMuted}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="CameraNoDeviceOverlay" Visibility="Collapsed" Panel.ZIndex="50" Background="{StaticResource OverlayStrong}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource FluentCameraIcon}" Width="54" Height="54" Stretch="Uniform" Fill="{StaticResource OverlayTextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                                <TextBlock Text="请连接摄像头以使用电脑录像" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextOnAccent}" HorizontalAlignment="Center"/>
                                <Button Content="重新检测" Width="112" Height="38" Margin="0,18,0,0" Style="{StaticResource PrimaryButtonStyle}" Focusable="False" Click="BtnRefreshCamera_Click"/>
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="PcRecordingControlOverlay" Visibility="Collapsed" Panel.ZIndex="45">
                            <Border Background="{StaticResource OverlayStrong}" CornerRadius="10"/>
                            <Button x:Name="BtnPreviewTogglePcRecording" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource TransparentBrush}" BorderThickness="0" Focusable="False" Cursor="Hand" Click="BtnTogglePcRecording_Click">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path x:Name="PcRecordingControlIcon" Data="{StaticResource FluentPauseIcon}" Width="52" Height="52" Stretch="Uniform" Fill="{StaticResource OverlayTextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PcRecordingControlText" Text="点击停用电脑录像" Margin="0,12,0,0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource OverlayTextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PcRecordingControlHint" Text="点击任意位置暂停摄像头" Margin="0,8,0,0" FontSize="14" Foreground="{StaticResource OverlayTextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

            <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" CornerRadius="10" Padding="14,12" Margin="0,20,0,0" MinHeight="104">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Height="64" Margin="0,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Barcode1Label}" Width="20" Margin="0,0,4,0" FontSize="13" FontWeight="SemiBold" LineHeight="18" TextAlignment="Center" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <Image Source="{Binding Barcode1Image}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="12,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode1Image}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="条码冷却中…" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding Barcode1CooldownProgress}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Column="1" Margin="4,0" Padding="12,8" CornerRadius="8" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <Rectangle x:Name="CurrentRecordingShimmerLayer" Margin="-12,-8" IsHitTestVisible="False">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentScanRecord}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <LinearGradientBrush.RelativeTransform>
                                            <TranslateTransform x:Name="CurrentRecordingShimmerTransform" X="-1.5"/>
                                        </LinearGradientBrush.RelativeTransform>
                                        <GradientStop Color="{StaticResource TransparentColor}" Offset="0"/>
                                        <GradientStop Color="{StaticResource RecordingShimmerEdgeColor}" Offset="0.3"/>
                                        <GradientStop Color="{StaticResource RecordingShimmerCoreColor}" Offset="0.5"/>
                                        <GradientStop Color="{StaticResource RecordingShimmerEdgeColor}" Offset="0.7"/>
                                        <GradientStop Color="{StaticResource TransparentColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CurrentRecordingShimmerTransform"
                                                                 Storyboard.TargetProperty="X"
                                                                 From="-1.5" To="1.5"
                                                                 Duration="0:0:2"
                                                                 RepeatBehavior="Forever">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Border CornerRadius="6" Padding="10,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentScanRecord}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="当前录像" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="等待扫描面单条码" Margin="0,8,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentScanRecord}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="当前录像" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Text="{Binding CurrentScanRecord.OrderId}" ToolTip="{Binding CurrentScanRecord.OrderId}" Margin="0,5" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="退货" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentOrange}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentScanRecord.Mode}" Value="退货">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentScanRecord.Duration, Converter={StaticResource LocalizedTextConverter}}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentRed}"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2" Height="64" Margin="12,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Barcode2Label}" Width="20" Margin="0,0,4,0" FontSize="13" FontWeight="SemiBold" LineHeight="18" TextAlignment="Center" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <Image Source="{Binding Barcode2Image}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="12,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode2Image}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="条码冷却中…" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding Barcode2CooldownProgress}" Foreground="{DynamicResource AccentBlue}" Background="{DynamicResource BorderStrong}" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

    </Grid>
</UserControl>

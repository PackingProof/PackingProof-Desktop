<Window x:Class="ExpressPackingMonitoring.UI.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打包数据深度分析" Height="720" Width="1100"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource WindowBackground}"
        Icon="/app.ico" FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <!-- 新增：维度切换按钮样式 -->
        <Style x:Key="MetricButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 筛选栏 -->
            <RowDefinition Height="Auto"/> <!-- 汇总卡片 -->
            <RowDefinition Height="*"/>    <!-- 图表区 -->
        </Grid.RowDefinitions>

        <!-- 1. 增强型工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="12" Padding="20,15" Margin="0,0,0,15" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="时间范围: " VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox x:Name="PresetCombo" Width="100" SelectionChanged="RangePresetCombo_SelectionChanged">
                        <ComboBoxItem Content="本周" Tag="Week"/>
                        <ComboBoxItem Content="本月" Tag="Month"/>
                        <ComboBoxItem Content="最近7天" Tag="Last7"/>
                        <ComboBoxItem Content="最近30天" Tag="Last30"/>
                        <ComboBoxItem Content="全部" Tag="All"/>
                    </ComboBox>
                    <DatePicker x:Name="PickerStart" Margin="10,0,5,0" Width="120" SelectedDateChanged="OnFilterChanged"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <DatePicker x:Name="PickerEnd" Margin="5,0,0,0" Width="120" SelectedDateChanged="OnFilterChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="查看维度: " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimary}"/>
                    <RadioButton Content="数量" IsChecked="True" x:Name="ModePieces" Style="{StaticResource MetricButtonStyle}" Click="OnFilterChanged"/>
                    <RadioButton Content="时长" x:Name="ModeDuration" Style="{StaticResource MetricButtonStyle}" Click="OnFilterChanged" Margin="5,0"/>
                    <RadioButton Content="大小" x:Name="ModeSize" Style="{StaticResource MetricButtonStyle}" Click="OnFilterChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="聚合方式: " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox x:Name="GroupCombo" Width="80" SelectionChanged="OnFilterChanged" SelectedIndex="0">
                        <ComboBoxItem Content="按日" Tag="day"/>
                        <ComboBoxItem Content="按周" Tag="week"/>
                        <ComboBoxItem Content="按月" Tag="month"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- 2. 汇总统计卡片 -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,15">
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="打包总件数" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding SummaryPieces}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="占用存储空间" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding SummarySize}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBlue}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="累计工作时长" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding SummaryDuration}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentGreen}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="平均单件用时" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding SummaryAvgTime}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentOrange}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 3. 图表显示区 -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="320"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding YAxisLabels[0]}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="1" Text="{Binding YAxisLabels[1]}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="2" Text="{Binding YAxisLabels[2]}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="3" Text="{Binding YAxisLabels[3]}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    <Grid Grid.Row="4">
                        <TextBlock Text="{Binding YAxisLabels[4]}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        <TextBlock Text="{Binding YAxisLabels[5]}" Foreground="{DynamicResource TextMuted}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>

                <Grid Grid.Row="0" Grid.Column="1" ClipToBounds="True">
                    <Grid IsHitTestVisible="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,0"/>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,0"/>
                        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,0"/>
                        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,0"/>
                        <Border Grid.Row="4" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,1"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ChartData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="1,0">
                                    <Border VerticalAlignment="Bottom" CornerRadius="3,3,0,0"
                                            Height="{Binding BarHeight}" MaxWidth="45">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentBlueDark}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ToolTip>
                                            <ToolTip Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Padding="10">
                                                <ToolTip.Effect>
                                                    <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                                                </ToolTip.Effect>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DateFull}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>
                                                    <Grid MinWidth="150">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Text="打包件数" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Pieces, StringFormat={}{0} 件}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Right"/>

                                                        <TextBlock Grid.Row="1" Text="总计时长" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalTime}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,5"/>

                                                        <TextBlock Grid.Row="2" Text="占用空间" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SizeText}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ChartData}" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Visibility="{Binding LabelVisibility}">
                                <TextBlock Text="{Binding DateLabel}" HorizontalAlignment="Center" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding DateSub}" HorizontalAlignment="Center" FontSize="9" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Window>

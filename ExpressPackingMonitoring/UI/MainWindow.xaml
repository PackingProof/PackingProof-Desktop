<Window x:Class="ExpressPackingMonitoring.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:ExpressPackingMonitoring.Localization"
        Title="打包监控" Height="850" Width="1350"
        Background="{DynamicResource WindowBackground}" WindowState="Maximized" MinWidth="760" MinHeight="680" Closing="Window_Closing" SizeChanged="Window_SizeChanged"
        Icon="/app.ico"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationColumn" Width="224"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel x:Name="ShellBrandPanel" Margin="8,0,8,24">
                    <TextBlock Text="打包监控" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="ShellBrandSubtitle" Text="录像 · 备份 · 订单" Margin="0,5,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavOverview" Content="统计" Tag="overview" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavPcRecording" Content="电脑录像" Tag="pc-recording" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavMobileBackup" Content="手机备份" Tag="mobile-backup" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavOrderIntegration" Content="订单联动" Tag="order-integration" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavVideoLibrary" Content="录像库" Tag="video-library" Height="44" Margin="0,0,0,6" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                    <Button x:Name="NavSettings" Content="设置" Tag="settings" Height="44" HorizontalContentAlignment="Left" Padding="16,0" Focusable="False" Click="NavigationButton_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock Text="今日概览" Margin="8,0,8,8" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                    <Border Padding="9,8" CornerRadius="8" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="今日本机" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="打包" Margin="0,0,5,1" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom"/>
                                    <TextBlock FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"><Run Text="{Binding TotalPieces, Mode=OneWay}"/><Run Text=" 个" FontSize="10"/></TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                    <TextBlock Text="均时" Margin="0,0,5,1" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Bottom"/>
                                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"><Run Text="{Binding AveragePackTimeDisplay.HourValue, Mode=OneWay}"/><Run Text="{Binding AveragePackTimeDisplay.HourUnit, Mode=OneWay}" FontSize="10"/><Run Text="{Binding AveragePackTimeDisplay.MinuteValue, Mode=OneWay}"/><Run Text="{Binding AveragePackTimeDisplay.MinuteUnit, Mode=OneWay}" FontSize="10"/><Run Text="{Binding AveragePackTimeDisplay.SecondValue, Mode=OneWay}"/><Run Text="{Binding AveragePackTimeDisplay.SecondUnit, Mode=OneWay}" FontSize="10"/></TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Margin="0,6,0,0" Padding="9,7" CornerRadius="7" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="备份手机" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding MobileBackup.TodayVideoCount, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text=" 个" Margin="0,0,0,1" FontSize="10" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
                <Border Grid.Row="4" Margin="0,18,0,0" Padding="8,10,8,0" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="连接状态" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MobileBackup.HasConnectedMobileDevices, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Grid.Column="1" Text="手机设备" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Grid.Column="2" Text="{Binding MobileBackup.ConnectedMobileDeviceCountText, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrderIntegration.IsRunning, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Grid.Column="1" Text="订单联动" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Grid.Column="2" Text="{Binding OrderIntegration.StatusText, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource TextMuted}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPrintWorkstationConnection}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Grid.Column="1" Text="打印工位" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Grid.Column="2" Text="{Binding PrintWorkstationConnectionText}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
        <Grid x:Name="PcRecordingModule" Visibility="Collapsed">
            <ContentControl x:Name="PcRecordingContentHost"/>
        </Grid>

        <ScrollViewer x:Name="OverviewModule" VerticalScrollBarVisibility="Auto">
            <ContentControl x:Name="OverviewStatisticsContentHost"/>
        </ScrollViewer>

        <Grid x:Name="MobileBackupModule" Visibility="Collapsed">
            <ContentControl x:Name="MobileBackupContentHost"/>
        </Grid>

        <Grid x:Name="OrderIntegrationModule" Visibility="Collapsed">
            <ContentControl x:Name="OrderIntegrationContentHost"/>
        </Grid>

        <Grid x:Name="VideoLibraryModule" Visibility="Collapsed">
            <ContentControl x:Name="VideoLibraryContentHost"/>
        </Grid>

        <Grid x:Name="SettingsModule" Visibility="Collapsed">
            <ContentControl x:Name="SettingsContentHost"/>
        </Grid>
        </Grid>

        <Border Grid.ColumnSpan="2" Background="{DynamicResource ToastBackground}" CornerRadius="8" Padding="32,16" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Panel.ZIndex="1000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}" Foreground="{StaticResource TextOnAccent}" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>



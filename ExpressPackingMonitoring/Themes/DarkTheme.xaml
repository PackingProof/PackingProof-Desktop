<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Window & Panel -->
    <SolidColorBrush x:Key="WindowBackground" Color="{DynamicResource Slate950Color}"/>
    <SolidColorBrush x:Key="PanelBackground" Color="{DynamicResource Slate800Color}"/>
    <SolidColorBrush x:Key="ControlBackground" Color="{DynamicResource Slate900Color}"/>
    <SolidColorBrush x:Key="ControlBackgroundHover" Color="{DynamicResource Slate700Color}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="{DynamicResource Slate50Color}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{DynamicResource Slate400Color}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{DynamicResource Slate500Color}"/>
    <SolidColorBrush x:Key="TextInvert" Color="{DynamicResource Slate800Color}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderLight" Color="{DynamicResource Slate700Color}"/>
    <SolidColorBrush x:Key="BorderDefault" Color="{DynamicResource Slate600Color}"/>
    <SolidColorBrush x:Key="BorderStrong" Color="{DynamicResource Slate500Color}"/>

    <!-- Accent / Status -->
    <SolidColorBrush x:Key="AccentBlue" Color="{DynamicResource Blue500Color}"/>
    <SolidColorBrush x:Key="AccentBlueDark" Color="{DynamicResource Blue400Color}"/>
    <SolidColorBrush x:Key="AccentGreen" Color="{DynamicResource Green500Color}"/>
    <SolidColorBrush x:Key="AccentRed" Color="{DynamicResource Red500Color}"/>
    <SolidColorBrush x:Key="AccentOrange" Color="{DynamicResource Amber500Color}"/>
    <SolidColorBrush x:Key="AccentPurple" Color="{DynamicResource Purple500Color}"/>
    <SolidColorBrush x:Key="AccentCyan" Color="{DynamicResource Cyan600Color}"/>
    <SolidColorBrush x:Key="DisabledActionBackground" Color="{DynamicResource Slate500Color}"/>

    <!-- List Item Status Colors -->
    <SolidColorBrush x:Key="BadgePackBg" Color="{DynamicResource Blue900Color}"/>
    <SolidColorBrush x:Key="BadgePackText" Color="{DynamicResource Blue200Color}"/>
    <SolidColorBrush x:Key="BadgeReturnBg" Color="{DynamicResource Amber900Color}"/>
    <SolidColorBrush x:Key="BadgeReturnText" Color="{DynamicResource Amber300Color}"/>
    <SolidColorBrush x:Key="BadgeErrorBg" Color="{DynamicResource Red900Color}"/>
    <SolidColorBrush x:Key="BadgeErrorText" Color="{DynamicResource Red300Color}"/>

    <!-- Misc -->
    <SolidColorBrush x:Key="ToastBackground" Color="{DynamicResource ToastDarkColor}"/>
    <SolidColorBrush x:Key="VideoPlaceholder" Color="{DynamicResource BlackColor}"/>
</ResourceDictionary>

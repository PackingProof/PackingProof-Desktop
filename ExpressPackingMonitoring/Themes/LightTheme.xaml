<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Window & Panel -->
    <SolidColorBrush x:Key="WindowBackground" Color="{DynamicResource CanvasLightColor}"/>
    <SolidColorBrush x:Key="PanelBackground" Color="{DynamicResource WhiteColor}"/>
    <SolidColorBrush x:Key="ControlBackground" Color="{DynamicResource Slate50Color}"/>
    <SolidColorBrush x:Key="ControlBackgroundHover" Color="{DynamicResource Slate100Color}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="{DynamicResource Slate800Color}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{DynamicResource Slate500Color}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{DynamicResource Slate400Color}"/>
    <SolidColorBrush x:Key="TextInvert" Color="{DynamicResource WhiteColor}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderLight" Color="{DynamicResource Slate100Color}"/>
    <SolidColorBrush x:Key="BorderDefault" Color="{DynamicResource Slate200Color}"/>
    <SolidColorBrush x:Key="BorderStrong" Color="{DynamicResource Slate300Color}"/>

    <!-- Accent / Status -->
    <SolidColorBrush x:Key="AccentBlue" Color="{DynamicResource Blue500Color}"/>
    <SolidColorBrush x:Key="AccentBlueDark" Color="{DynamicResource Blue600Color}"/>
    <SolidColorBrush x:Key="AccentGreen" Color="{DynamicResource Green500Color}"/>
    <SolidColorBrush x:Key="AccentRed" Color="{DynamicResource Red500Color}"/>
    <SolidColorBrush x:Key="AccentOrange" Color="{DynamicResource Amber500Color}"/>
    <SolidColorBrush x:Key="AccentPurple" Color="{DynamicResource Purple500Color}"/>
    <SolidColorBrush x:Key="AccentCyan" Color="{DynamicResource Cyan600Color}"/>
    <SolidColorBrush x:Key="DisabledActionBackground" Color="{DynamicResource Slate500Color}"/>

    <!-- List Item Status Colors -->
    <SolidColorBrush x:Key="BadgePackBg" Color="{DynamicResource Blue100Color}"/>
    <SolidColorBrush x:Key="BadgePackText" Color="{DynamicResource Blue700Color}"/>
    <SolidColorBrush x:Key="BadgeReturnBg" Color="{DynamicResource Amber100Color}"/>
    <SolidColorBrush x:Key="BadgeReturnText" Color="{DynamicResource Amber600Color}"/>
    <SolidColorBrush x:Key="BadgeErrorBg" Color="{DynamicResource Red100Color}"/>
    <SolidColorBrush x:Key="BadgeErrorText" Color="{DynamicResource Red600Color}"/>

    <!-- Misc -->
    <SolidColorBrush x:Key="ToastBackground" Color="{DynamicResource ToastLightColor}"/>
    <SolidColorBrush x:Key="VideoPlaceholder" Color="{DynamicResource Slate900Color}"/>
</ResourceDictionary>

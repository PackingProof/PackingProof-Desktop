<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Neutral palette -->
    <Color x:Key="TransparentColor">#00FFFFFF</Color>
    <Color x:Key="WhiteColor">#FFFFFFFF</Color>
    <Color x:Key="BlackColor">#FF000000</Color>
    <Color x:Key="Slate950Color">#FF0B1120</Color>
    <Color x:Key="Slate900Color">#FF0F172A</Color>
    <Color x:Key="Slate800Color">#FF1E293B</Color>
    <Color x:Key="Slate700Color">#FF334155</Color>
    <Color x:Key="Slate600Color">#FF475569</Color>
    <Color x:Key="Slate500Color">#FF64748B</Color>
    <Color x:Key="Slate400Color">#FF94A3B8</Color>
    <Color x:Key="Slate300Color">#FFCBD5E1</Color>
    <Color x:Key="Slate200Color">#FFE2E8F0</Color>
    <Color x:Key="Slate100Color">#FFF1F5F9</Color>
    <Color x:Key="Slate50Color">#FFF8FAFC</Color>
    <Color x:Key="CanvasLightColor">#FFF3F4F6</Color>

    <!-- Restrained accent palette -->
    <Color x:Key="Blue700Color">#FF1D4ED8</Color>
    <Color x:Key="Blue600Color">#FF2563EB</Color>
    <Color x:Key="Blue500Color">#FF3B82F6</Color>
    <Color x:Key="Blue400Color">#FF60A5FA</Color>
    <Color x:Key="Blue200Color">#FF93C5FD</Color>
    <Color x:Key="Blue100Color">#FFDBEAFE</Color>
    <Color x:Key="Blue900Color">#FF1E3A8A</Color>
    <Color x:Key="Green500Color">#FF10B981</Color>
    <Color x:Key="Red600Color">#FFDC2626</Color>
    <Color x:Key="Red500Color">#FFEF4444</Color>
    <Color x:Key="Red300Color">#FFFCA5A5</Color>
    <Color x:Key="Red100Color">#FFFEE2E2</Color>
    <Color x:Key="Red900Color">#FF7F1D1D</Color>
    <Color x:Key="Amber600Color">#FFD97706</Color>
    <Color x:Key="Amber500Color">#FFF59E0B</Color>
    <Color x:Key="Amber300Color">#FFFCD34D</Color>
    <Color x:Key="Amber100Color">#FFFEF3C7</Color>
    <Color x:Key="Amber900Color">#FF78350F</Color>
    <Color x:Key="Purple500Color">#FF8B5CF6</Color>
    <Color x:Key="Cyan600Color">#FF0EA5E9</Color>

    <!-- Invariant UI and camera overlay colors -->
    <Color x:Key="ToastLightColor">#CC0F172A</Color>
    <Color x:Key="ToastDarkColor">#CC334155</Color>
    <Color x:Key="OverlayMediumColor">#8F0F172A</Color>
    <Color x:Key="OverlayStrongColor">#E61E293B</Color>
    <Color x:Key="OverlaySoftColor">#661E293B</Color>
    <Color x:Key="OverlayTextPrimaryColor">#CCFFFFFF</Color>
    <Color x:Key="OverlayTextSecondaryColor">#AAFFFFFF</Color>
    <Color x:Key="OverlayTextMutedColor">#88FFFFFF</Color>
    <Color x:Key="CameraGuideStrokeColor">#CC3B82F6</Color>
    <Color x:Key="CameraGuideFillColor">#103B82F6</Color>
    <Color x:Key="CameraCandidateStrokeColor">#FFF59E0B</Color>
    <Color x:Key="CameraCandidateFillColor">#18F59E0B</Color>
    <Color x:Key="CameraConfirmedStrokeColor">#FF10B981</Color>
    <Color x:Key="CameraConfirmedFillColor">#1810B981</Color>
    <Color x:Key="WarningOverlayColor">#E6D97706</Color>
    <Color x:Key="DangerOverlayColor">#E6DC2626</Color>
    <Color x:Key="WarningOverlayBorderColor">#FFFCD34D</Color>
    <Color x:Key="DangerOverlayBorderColor">#FFFCA5A5</Color>
    <Color x:Key="RecordingShimmerEdgeColor">#10EF4444</Color>
    <Color x:Key="RecordingShimmerCoreColor">#B0EF4444</Color>

    <SolidColorBrush x:Key="TransparentBrush" Color="{StaticResource TransparentColor}"/>
    <SolidColorBrush x:Key="TextOnAccent" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="TextOnLightAccent" Color="{StaticResource Slate900Color}"/>
    <SolidColorBrush x:Key="QrCodeBackground" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="BarcodeBackground" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="BarcodeForeground" Color="{StaticResource BlackColor}"/>
    <SolidColorBrush x:Key="OverlayMedium" Color="{StaticResource OverlayMediumColor}"/>
    <SolidColorBrush x:Key="OverlayStrong" Color="{StaticResource OverlayStrongColor}"/>
    <SolidColorBrush x:Key="OverlaySoft" Color="{StaticResource OverlaySoftColor}"/>
    <SolidColorBrush x:Key="OverlayTextPrimary" Color="{StaticResource OverlayTextPrimaryColor}"/>
    <SolidColorBrush x:Key="OverlayTextSecondary" Color="{StaticResource OverlayTextSecondaryColor}"/>
    <SolidColorBrush x:Key="OverlayTextMuted" Color="{StaticResource OverlayTextMutedColor}"/>
    <SolidColorBrush x:Key="CameraGuideStroke" Color="{StaticResource CameraGuideStrokeColor}"/>
    <SolidColorBrush x:Key="CameraGuideFill" Color="{StaticResource CameraGuideFillColor}"/>
    <SolidColorBrush x:Key="CameraCandidateStroke" Color="{StaticResource CameraCandidateStrokeColor}"/>
    <SolidColorBrush x:Key="CameraCandidateFill" Color="{StaticResource CameraCandidateFillColor}"/>
    <SolidColorBrush x:Key="CameraConfirmedStroke" Color="{StaticResource CameraConfirmedStrokeColor}"/>
    <SolidColorBrush x:Key="CameraConfirmedFill" Color="{StaticResource CameraConfirmedFillColor}"/>
    <SolidColorBrush x:Key="WarningOverlay" Color="{StaticResource WarningOverlayColor}"/>
    <SolidColorBrush x:Key="DangerOverlay" Color="{StaticResource DangerOverlayColor}"/>
    <SolidColorBrush x:Key="WarningOverlayBorder" Color="{StaticResource WarningOverlayBorderColor}"/>
    <SolidColorBrush x:Key="DangerOverlayBorder" Color="{StaticResource DangerOverlayBorderColor}"/>
</ResourceDictionary>
